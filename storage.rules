rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Profile images: any authenticated user can read (so followers can see
    // other users' avatars), but only the owner can write their own image.
    match /profiles/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && filename.matches(request.auth.uid + '.*');
    }

    // Rule for posts:
    // Currently, any authenticated user can read or write any file in the /posts/
    // directory. You might want to make this more restrictive.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}