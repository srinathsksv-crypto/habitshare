rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Corrected rule for user profile images:
    // This allows authenticated users to read and write their own profile image,
    // assuming the image is named with their UID followed by ".jpg"
    // (e.g., /profiles/someUserId.jpg).
    match /profiles/{filename} {
      allow read: if request.auth != null && filename == request.auth.uid + '.jpg';
      allow write: if request.auth != null && filename == request.auth.uid + '.jpg';
    }

    // Rule for posts:
    // Currently, any authenticated user can read or write any file in the /posts/
    // directory. You might want to make this more restrictive.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}