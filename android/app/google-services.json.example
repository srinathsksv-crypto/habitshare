        {
          "client_id": "YOUR_PROJECT_NUMBER-yyyy.apps.googleusercontent.com",
          "client_type": 1,
          "android_info": {
            "package_name": "com.example.habitshare",
            "certificate_hash": "YOUR_RELEASE_SHA1_WITHOUT_COLONS"
